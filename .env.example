# ---------------------------------------------------------------------------
# V-AEP root env example. Copy to .env (root) for shared/local dev values.
# The API reads these (see apps/api/src/config). The web app reads NEXT_PUBLIC_*.
# Infra (docker-compose) has its own infra/.env.example.
# ---------------------------------------------------------------------------

# --- Database (points at the docker-compose postgres on localhost) ---
DATABASE_URL="postgresql://vaep:vaep@localhost:5433/vaep?schema=public"

# --- Auth / JWT (CHANGE THESE for anything but local dev) ---
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TTL="900s"
REFRESH_TTL="7d"

# --- API server ---
PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# --- Web (Next.js public runtime) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Redis (BullMQ queues; docker on 6380 to avoid local redis) ---
REDIS_URL="redis://127.0.0.1:6380"

# --- Queue workers (default true everywhere) ---
# Set to "false" ONLY on the Vercel apps/api project (apps/api/api/index.ts,
# HTTP-only serverless entry) so it doesn't run BullMQ consumers. Leave unset
# on whatever host runs the persistent worker (main.ts, app.listen).
# QUEUE_WORKERS_ENABLED="false"

# --- AI Employee runtime (all optional; default is fully offline) ---
# LLM backend: mock (default, deterministic/offline) | anthropic | openai
LLM_PROVIDER="mock"
# LLM_MODEL="claude-sonnet-5"       # override (anthropic) / gpt-4o-mini (openai)
# ANTHROPIC_API_KEY="sk-ant-..."    # required when LLM_PROVIDER=anthropic
# OPENAI_API_KEY="sk-..."           # required when LLM_PROVIDER=openai (shared with embeddings)

# --- Secrets encryption at rest (skill credentials, etc.) ---
# 32-byte AES-256 key: 64 hex chars OR base64 of 32 bytes. Optional in dev (an
# insecure key is derived with a warning); MUST be set in production.
# Generate: openssl rand -hex 32
# ENCRYPTION_KEY="<64-hex-chars-or-base64-32-bytes>"
