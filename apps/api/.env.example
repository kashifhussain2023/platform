# API env example. Copy to apps/api/.env, OR rely on the root .env
# (config.module.ts reads both ['.env', '../../.env']).
DATABASE_URL="postgresql://vaep:vaep@localhost:5433/vaep?schema=public"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TTL="900s"
REFRESH_TTL="7d"
PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# --- Redis (BullMQ queues; docker on 6380 to avoid local redis) ---
REDIS_URL="redis://127.0.0.1:6380"

# --- Knowledge / RAG (all optional; defaults are zero-infra) ---
# Embeddings: hash (default, offline/deterministic) | local (@xenova) | openai
EMBEDDINGS_PROVIDER="hash"
# Storage: local (default, filesystem) | s3 (MinIO/S3-compatible)
STORAGE_PROVIDER="local"
# STORAGE_DIR=".storage"            # LocalStorageProvider base dir
# OPENAI_API_KEY="sk-..."           # required when EMBEDDINGS_PROVIDER=openai
# S3_ENDPOINT="http://localhost:9000"  # MinIO; required when STORAGE_PROVIDER=s3
# S3_BUCKET="vaep"
# S3_ACCESS_KEY="minio"
# S3_SECRET_KEY="minio12345"

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...        # model defaults to claude-sonnet-5

# --- Secrets encryption at rest (skill credentials, etc.) ---
# 32-byte AES-256 key: 64 hex chars OR base64 of 32 bytes. Optional in dev (an
# insecure key is derived with a warning); MUST be set in production.
# Generate: openssl rand -hex 32
# ENCRYPTION_KEY="<64-hex-chars-or-base64-32-bytes>"

# --- Marketing engine (Postiz, self-hosted) ---
POSTIZ_BASE_URL=http://postiz:3000
POSTIZ_API_KEY=
