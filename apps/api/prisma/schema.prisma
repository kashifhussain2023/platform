// V-AEP Prisma schema — Foundation + Auth/Tenant slice.
// Every future table carries `companyId`; the tenant guard scopes all queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum EmployeeRole {
  SUPPORT
  SALES
  RECRUITER
  HR
  ACCOUNTANT
  PROJECT_MANAGER
  CUSTOM
}

enum EmployeeStatus {
  ACTIVE
  PAUSED
  DISABLED
}

// Whether an AI employee may retrieve from the company knowledge base at all.
// ALL (default) preserves current retrieval behaviour; NONE skips retrieval.
enum KnowledgeAccess {
  ALL
  NONE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryKind {
  FACT
  SUMMARY
}

enum SkillExecutionStatus {
  SUCCESS
  ERROR
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum StepRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  // Company profile (Step 2 richer registration + onboarding wizard). Optional.
  industry    String?
  size        String?
  country     String?
  timezone    String?
  website     String?
  logoUrl     String?
  description String?
  // Set when the AI Onboarding Wizard is completed; null = not yet onboarded.
  onboardedAt DateTime?
  createdAt   DateTime  @default(now())

  users              User[]
  knowledgeDocuments KnowledgeDocument[]
  aiEmployees        AiEmployee[]
  installedSkills    InstalledSkill[]
  workflows          Workflow[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  @@unique([companyId, email])
}

// --- Knowledge / RAG -------------------------------------------------------
// pgvector powers similarity search. Prisma cannot read/write the vector column
// (it is `Unsupported`), so embeddings are inserted/queried via $executeRaw /
// $queryRaw with a `::vector` cast. The hnsw index is added in the migration SQL.

model KnowledgeDocument {
  id         String           @id @default(cuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  status     DocumentStatus   @default(PENDING)
  error      String?
  chunkCount Int              @default(0)
  createdAt  DateTime         @default(now())

  chunks KnowledgeChunk[]

  @@index([companyId])
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  documentId String
  document   KnowledgeDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  companyId  String
  content    String
  chunkIndex Int
  embedding  Unsupported("vector(384)")?
  createdAt  DateTime                     @default(now())

  @@index([companyId])
}

// --- AI Employee runtime ---------------------------------------------------
// No vector columns here: memory is recalled by recency (see EmployeeMemory /
// Message). Retrieval reuses the Knowledge module's pgvector search.

model AiEmployee {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  role      EmployeeRole
  status    EmployeeStatus @default(ACTIVE)
  persona   String?
  model     String?
  // Rich employee configuration (Step 5). All optional; sensible defaults apply.
  department        String?
  managerName       String?
  workingHoursStart String?
  workingHoursEnd   String?
  timezone          String?
  language          String?
  // Whether this employee may retrieve from the company knowledge base.
  knowledgeAccess   KnowledgeAccess @default(ALL)
  budgetLimit       Int?
  // Free-form permission flags + approval rules (enforced by a future Approval Center).
  permissions       Json?
  approvalRules     Json?
  createdAt DateTime       @default(now())

  conversations  Conversation[]
  memories       EmployeeMemory[]
  employeeSkills EmployeeSkill[]

  @@index([companyId])
}

model Conversation {
  id         String     @id @default(cuid())
  companyId  String
  employeeId String
  employee   AiEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String?
  createdAt  DateTime   @default(now())

  messages Message[]

  @@index([companyId])
}

model Message {
  id             String       @id @default(cuid())
  companyId      String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([companyId])
}

model EmployeeMemory {
  id         String     @id @default(cuid())
  companyId  String
  employeeId String
  employee   AiEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  kind       MemoryKind
  content    String
  createdAt  DateTime   @default(now())

  @@index([companyId])
}

// --- Skills ----------------------------------------------------------------
// A code-defined CATALOG of built-in skills (see modules/skills/catalog.ts) is
// the source of truth for tools/params — the DB only tracks which skills a
// company has INSTALLED, which employees they are ASSIGNED to, and an audit log
// of executions. No vector columns here.

model InstalledSkill {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skillKey    String
  displayName String
  config      Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  employees EmployeeSkill[]

  @@unique([companyId, skillKey])
  @@index([companyId])
}

model EmployeeSkill {
  id               String   @id @default(cuid())
  companyId        String
  employeeId       String
  installedSkillId String
  createdAt        DateTime @default(now())

  employee       AiEmployee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  installedSkill InstalledSkill @relation(fields: [installedSkillId], references: [id], onDelete: Cascade)

  @@unique([employeeId, installedSkillId])
  @@index([companyId])
}

model SkillExecution {
  id             String               @id @default(cuid())
  companyId      String
  employeeId     String?
  conversationId String?
  skillKey       String
  tool           String
  args           Json
  result         Json?
  status         SkillExecutionStatus
  error          String?
  createdAt      DateTime             @default(now())

  @@index([companyId])
}

// --- Workflow builder ------------------------------------------------------
// A no-code engine chaining trigger → AI step → retrieve → tool action → wait →
// condition → notify. `definition` is the graph ({nodes, edges}); running a
// workflow creates a WorkflowRun (executed async via BullMQ) that walks the
// graph writing a WorkflowStepRun per visited node. No vector columns here.

model Workflow {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  definition  Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  runs WorkflowRun[]

  @@index([companyId])
}

model WorkflowRun {
  id         String            @id @default(cuid())
  companyId  String
  workflowId String
  workflow   Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status     WorkflowRunStatus @default(PENDING)
  trigger    Json?
  context    Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime          @default(now())

  steps WorkflowStepRun[]

  @@index([companyId])
}

model WorkflowStepRun {
  id         String        @id @default(cuid())
  companyId  String
  runId      String
  run        WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String
  type       String
  status     StepRunStatus @default(PENDING)
  input      Json?
  output     Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([companyId])
}
