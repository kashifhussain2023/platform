// V-AEP Prisma schema — Foundation + Auth/Tenant slice.
// Every future table carries `companyId`; the tenant guard scopes all queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

// Whether a user account may authenticate. DISABLED users are rejected at login
// (RBAC + user management, P0 governance). Company creators are always ACTIVE.
enum UserStatus {
  ACTIVE
  DISABLED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum EmployeeRole {
  SUPPORT
  SALES
  RECRUITER
  HR
  ACCOUNTANT
  PROJECT_MANAGER
  CUSTOM
}

enum EmployeeStatus {
  ACTIVE
  PAUSED
  DISABLED
}

// Whether an AI employee may retrieve from the company knowledge base at all.
// ALL (default) preserves current retrieval behaviour; NONE skips retrieval.
enum KnowledgeAccess {
  ALL
  NONE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryKind {
  FACT
  SUMMARY
}

// Manager feedback on an AI output (Step 15 continuous learning). A 👍/👎 signal;
// a 👎 with a correction (or an explicit teach) also becomes a durable FACT memory.
enum FeedbackRating {
  UP
  DOWN
}

enum SkillExecutionStatus {
  SUCCESS
  ERROR
}

// Whether an installed skill has been connected to its (real) backend.
enum SkillConnectionStatus {
  NOT_CONNECTED
  CONNECTED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
}

// How an ACTIVE workflow is invoked. MANUAL is the default and preserves the
// existing POST /workflows/:id/run path; SCHEDULE/WEBHOOK/EVENT are event-driven.
enum TriggerType {
  MANUAL
  SCHEDULE
  WEBHOOK
  EVENT
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum StepRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Subscription plan tiers (from the proposal pricing). STARTER is the default
// plan every company gets at registration.
enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  // Company profile (Step 2 richer registration + onboarding wizard). Optional.
  industry    String?
  size        String?
  country     String?
  timezone    String?
  website     String?
  logoUrl     String?
  description String?
  // Set when the AI Onboarding Wizard is completed; null = not yet onboarded.
  onboardedAt DateTime?
  createdAt   DateTime  @default(now())

  users              User[]
  knowledgeDocuments KnowledgeDocument[]
  aiEmployees        AiEmployee[]
  installedSkills    InstalledSkill[]
  workflows          Workflow[]
  approvalRequests   ApprovalRequest[]
  subscription       Subscription?
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(MEMBER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime @default(now())

  @@unique([companyId, email])
}

// --- Knowledge / RAG -------------------------------------------------------
// pgvector powers similarity search. Prisma cannot read/write the vector column
// (it is `Unsupported`), so embeddings are inserted/queried via $executeRaw /
// $queryRaw with a `::vector` cast. The hnsw index is added in the migration SQL.

model KnowledgeDocument {
  id         String           @id @default(cuid())
  companyId  String
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  status     DocumentStatus   @default(PENDING)
  error      String?
  chunkCount Int              @default(0)
  createdAt  DateTime         @default(now())

  chunks KnowledgeChunk[]

  @@index([companyId])
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  documentId String
  document   KnowledgeDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  companyId  String
  content    String
  chunkIndex Int
  embedding  Unsupported("vector(384)")?
  createdAt  DateTime                     @default(now())

  @@index([companyId])
}

// --- AI Employee runtime ---------------------------------------------------
// No vector columns here: memory is recalled by recency (see EmployeeMemory /
// Message). Retrieval reuses the Knowledge module's pgvector search.

model AiEmployee {
  id        String         @id @default(cuid())
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  role      EmployeeRole
  status    EmployeeStatus @default(ACTIVE)
  persona   String?
  model     String?
  // Rich employee configuration (Step 5). All optional; sensible defaults apply.
  department        String?
  managerName       String?
  workingHoursStart String?
  workingHoursEnd   String?
  timezone          String?
  language          String?
  // Whether this employee may retrieve from the company knowledge base.
  knowledgeAccess   KnowledgeAccess @default(ALL)
  budgetLimit       Int?
  // Free-form permission flags + approval rules (enforced by a future Approval Center).
  permissions       Json?
  approvalRules     Json?
  createdAt DateTime       @default(now())

  conversations  Conversation[]
  memories       EmployeeMemory[]
  employeeSkills EmployeeSkill[]
  feedback       EmployeeFeedback[]

  @@index([companyId])
}

model Conversation {
  id         String     @id @default(cuid())
  companyId  String
  employeeId String
  employee   AiEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String?
  createdAt  DateTime   @default(now())

  messages Message[]

  @@index([companyId])
}

model Message {
  id             String       @id @default(cuid())
  companyId      String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([companyId])
}

model EmployeeMemory {
  id         String     @id @default(cuid())
  companyId  String
  employeeId String
  employee   AiEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  kind       MemoryKind
  content    String
  // Where this memory came from: 'FEEDBACK' | 'MANUAL' | 'RUN'. Nullable so the
  // existing rolling SUMMARY writes (RUN) are unaffected (they leave it null).
  source     String?
  createdAt  DateTime   @default(now())

  @@index([companyId])
}

// Manager feedback on a specific AI output (Step 15 continuous learning). A 👎
// with a correction (or teach=true) also spawns a durable FACT EmployeeMemory so
// the runtime recalls the lesson on future runs — closing the improvement loop.
model EmployeeFeedback {
  id             String         @id @default(cuid())
  companyId      String
  employeeId     String
  employee       AiEmployee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  conversationId String?
  messageId      String?
  rating         FeedbackRating
  note           String?
  correction     String?
  createdAt      DateTime       @default(now())

  @@index([companyId])
  @@index([employeeId])
}

// --- Skills ----------------------------------------------------------------
// A code-defined CATALOG of built-in skills (see modules/skills/catalog.ts) is
// the source of truth for tools/params — the DB only tracks which skills a
// company has INSTALLED, which employees they are ASSIGNED to, and an audit log
// of executions. No vector columns here.

model InstalledSkill {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skillKey    String
  displayName String
  // Non-secret company-specific settings (mirrors the catalog configSchema).
  config      Json?
  enabled     Boolean  @default(true)
  // Connection state. connectionType mirrors the catalog ('oauth'|'api_key'|'none');
  // credentials holds SECRETS (api keys / oauth tokens) and is NEVER returned raw.
  connectionType   String?
  connectionStatus SkillConnectionStatus @default(NOT_CONNECTED)
  credentials      Json?
  createdAt   DateTime @default(now())

  employees EmployeeSkill[]

  @@unique([companyId, skillKey])
  @@index([companyId])
}

model EmployeeSkill {
  id               String   @id @default(cuid())
  companyId        String
  employeeId       String
  installedSkillId String
  createdAt        DateTime @default(now())

  employee       AiEmployee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  installedSkill InstalledSkill @relation(fields: [installedSkillId], references: [id], onDelete: Cascade)

  @@unique([employeeId, installedSkillId])
  @@index([companyId])
}

model SkillExecution {
  id             String               @id @default(cuid())
  companyId      String
  employeeId     String?
  conversationId String?
  skillKey       String
  tool           String
  args           Json
  result         Json?
  status         SkillExecutionStatus
  error          String?
  createdAt      DateTime             @default(now())

  @@index([companyId])
}

// --- Workflow builder ------------------------------------------------------
// A no-code engine chaining trigger → AI step → retrieve → tool action → wait →
// condition → notify. `definition` is the graph ({nodes, edges}); running a
// workflow creates a WorkflowRun (executed async via BullMQ) that walks the
// graph writing a WorkflowStepRun per visited node. No vector columns here.

model Workflow {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  definition  Json
  // Trigger configuration (Steps 8/9/11). MANUAL keeps the existing run path.
  triggerType   TriggerType @default(MANUAL)
  // SCHEDULE: { everyMs?, cron? } · EVENT: { eventType } · WEBHOOK/MANUAL: none.
  triggerConfig Json?
  // Random token for the public webhook URL (WEBHOOK triggers); generated on activate.
  webhookToken  String?     @unique
  // Set when the workflow was last activated; null = never activated.
  activatedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  runs WorkflowRun[]

  @@index([companyId])
}

model WorkflowRun {
  id         String            @id @default(cuid())
  companyId  String
  workflowId String
  workflow   Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status     WorkflowRunStatus @default(PENDING)
  // How this run was triggered: MANUAL (default) | SCHEDULE | WEBHOOK | EVENT.
  source     String            @default("MANUAL")
  trigger    Json?
  context    Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime          @default(now())

  steps WorkflowStepRun[]

  @@index([companyId])
}

model WorkflowStepRun {
  id         String        @id @default(cuid())
  companyId  String
  runId      String
  run        WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String
  type       String
  status     StepRunStatus @default(PENDING)
  input      Json?
  output     Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([companyId])
}

// --- Approval Center -------------------------------------------------------
// A HIGH-RISK tool call (per the skills catalog `highRisk` flag or an employee's
// `approvalRules`) is captured here as PENDING instead of executing. A manager
// approves (→ execute now, via SkillsService.runTool), rejects (→ skip) or
// modifies (→ edit args then execute). No vector columns here.

model ApprovalRequest {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId     String?
  conversationId String?
  skillKey       String
  tool           String
  args           Json
  result         Json?
  description    String?
  status         ApprovalStatus @default(PENDING)
  decidedById    String?
  decidedAt      DateTime?
  note           String?
  createdAt      DateTime       @default(now())

  @@index([companyId])
  @@index([companyId, status])
}

// --- Billing & Subscription (Steps 1 + 13) ---------------------------------
// One subscription per company. Every company gets a default STARTER/ACTIVE
// subscription at registration (idempotent upsert on the unique companyId).
// The active BillingProvider (mock by default, Stripe opt-in) is swappable via
// the BILLING_PROVIDER env var; plan limits are SOFT (informational only — not
// enforced). No vector columns here.

model Subscription {
  id                    String             @id @default(cuid())
  companyId             String             @unique
  company               Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                  Plan               @default(STARTER)
  status                SubscriptionStatus @default(ACTIVE)
  // Which BillingProvider owns this subscription ("mock" | "stripe").
  provider              String             @default("mock")
  // Opaque provider references (e.g. Stripe customer/subscription ids).
  externalCustomerId    String?
  externalSubscriptionId String?
  currentPeriodEnd      DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}
