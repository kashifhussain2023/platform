# Infra env example. Copy to infra/.env (optional — the compose file has
# sensible ${VAR:-default} fallbacks so it also runs with no env file).

# --- Postgres (pgvector) ---
POSTGRES_USER=vaep
POSTGRES_PASSWORD=vaep
POSTGRES_DB=vaep

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345

# Reference: the API should point DATABASE_URL at this Postgres:
#   postgresql://vaep:vaep@localhost:5432/vaep?schema=public
