{
  "name": "@vaep/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared config presets for V-AEP: tsconfig base, eslint, tailwind.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tsconfig": "./tsconfig.base.json",
    "./eslint": "./eslint-preset.cjs",
    "./tailwind": "./tailwind-preset.cjs"
  },
  "files": [
    "src",
    "tsconfig.base.json",
    "eslint-preset.cjs",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
